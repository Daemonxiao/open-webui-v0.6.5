region                  = "cn-beijing"
project_name            = "open-webui"
environment             = "hai"
app_port                = 3000
app_ingress_cidr_blocks = ["0.0.0.0/0"]
new_api_port                = 3001
new_api_ingress_cidr_blocks = ["0.0.0.0/0"]

# Leave instance_type empty to auto-select an available 8C16G type in the selected zone.
# To pin an exact ECS class, set instance_type, for example "ecs.u1-c1m2.2xlarge".
instance_type = ""
ecs_cpu_core_count = 8
ecs_memory_size    = 16

# Optional: set this if you want a specific zone, for example "cn-beijing-k".
zone_id = ""

# RDS PostgreSQL is created by default for Open WebUI metadata persistence.
rds_engine_version   = "13.0"
rds_instance_type    = ""
rds_instance_storage = 30
new_api_database_name    = "newapi"
new_api_rds_account_name = "newapi"

# Redis is not required for the default single ECS deployment.
# Set both values only if you later deploy multiple Open WebUI instances.
redis_url         = ""
websocket_manager = ""
